{
  "name": "enconvo-cli",
  "version": "2.0.0",
  "description": "EnConvo CLI — manage channels, agents, and more",
  "main": "src/index.ts",
  "bin": {
    "enconvo": "./src/cli.ts"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "install-service": "bash scripts/install.sh",
    "uninstall-service": "bash scripts/uninstall.sh",
    "logs": "tail -f ~/Library/Logs/enconvo-telegram-adapter.log"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "commander": "^14.0.3",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "grammy": "^1.40.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
